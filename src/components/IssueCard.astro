---
import type { Issue } from '../lib/linear';

interface Props {
  issue: Issue;
  stateType: string;
}

const { issue, stateType } = Astro.props;
const isDone = stateType === 'completed' || stateType === 'cancelled';

let completedLabel: string | null = null;
if (isDone && issue.completedAt) {
  const d = new Date(issue.completedAt);
  completedLabel = `✓ ${d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}`;
}

let dueDateLabel: string | null = null;
let isOverdue = false;
if (issue.dueDate) {
  const [y, m, day] = issue.dueDate.split('-').map(Number);
  const due = new Date(y, m - 1, day);
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  const diff = Math.round((due.getTime() - now.getTime()) / 86400000);
  isOverdue = diff < 0 && !isDone;
  if (diff < 0) dueDateLabel = isDone ? null : `En retard de ${Math.abs(diff)}j`;
  else if (diff === 0) dueDateLabel = "Aujourd'hui";
  else if (diff === 1) dueDateLabel = "Demain";
  else dueDateLabel = `Dans ${diff}j`;
}
---

<div class="card">
  <div class="title">{issue.title}</div>
  {completedLabel && <div class="meta success">{completedLabel}</div>}
  {dueDateLabel && <div class={`meta ${isOverdue ? 'danger' : ''}`}>📅 {dueDateLabel}</div>}
</div>

<style>
  .card {
    background: var(--brand-card-bg, #f8f9fa);
    border: 1px solid var(--brand-border, #e8e8e8);
    border-radius: 6px;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .title {
    font-weight: 500;
    color: #1a1a1a;
    overflow-wrap: break-word;
  }
  .meta {
    margin-top: 0.35rem;
    font-size: 0.75rem;
    color: #6b7280;
  }
  .meta.success { color: #16a34a; }
  .meta.danger  { color: #dc2626; font-weight: 600; }
</style>
