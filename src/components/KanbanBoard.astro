---
import KanbanColumn from './KanbanColumn.astro';
import type { BacklogData } from '../lib/linear';

interface Props {
  columns: BacklogData;
  label: string;
}

const { columns, label } = Astro.props;
---

{columns.length === 0 ? (
  <p class="empty">
    No issues found. Add the <code>{label}</code> label to Linear issues to display them here.
  </p>
) : (
  <div class="board">
    {columns.map(col => (
      <KanbanColumn state={col.state} issues={col.issues} />
    ))}
  </div>
)}

<style>
  .board {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 2rem;
    overflow-x: auto;
    align-items: flex-start;
    min-height: calc(100vh - 64px);
  }
  .empty {
    padding: 3rem 2rem;
    color: #888;
    font-size: 1rem;
  }
  code {
    background: #f0f0f0;
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-size: 0.9em;
  }
</style>
