---
import KanbanColumn from './KanbanColumn.astro';
import type { BacklogData } from '../lib/linear';
import type { getT } from '../lib/i18n';

interface Props {
  columns: BacklogData;
  label: string;
  t: ReturnType<typeof getT>;
}

const { columns, label, t } = Astro.props;
---

{columns.length === 0 ? (
  <p class="empty">{t.empty(label)}</p>
) : (
  <div class="board">
    {columns.map(col => (
      <KanbanColumn state={col.state} issues={col.issues} t={t} />
    ))}
  </div>
)}

<style>
  .board {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 2rem;
    overflow-x: auto;
    align-items: flex-start;
    min-height: calc(100vh - 64px);
  }
  .empty {
    padding: 3rem 2rem;
    color: #888;
    font-size: 1rem;
  }
</style>
