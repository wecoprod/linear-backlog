---
import IssueCard from './IssueCard.astro';
import type { WorkflowState, Issue } from '../lib/linear';

interface Props {
  state: WorkflowState;
  issues: Issue[];
}

const { state, issues } = Astro.props;
---

<div class="column">
  <div class="column-header">
    <span class="dot" style={`background: ${state.color}`}></span>
    {state.name}
    <span class="count">{issues.length}</span>
  </div>
  <div class="issue-list">
    {issues.map(issue => <IssueCard issue={issue} />)}
  </div>
</div>

<style>
  .column {
    background: #fff;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    min-width: 280px;
    max-width: 320px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
  }
  .column-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid #e0e0e0;
    font-weight: 600;
    font-size: 0.875rem;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .count {
    margin-left: auto;
    font-weight: 400;
    color: #888;
    font-size: 0.8rem;
  }
  .issue-list {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
