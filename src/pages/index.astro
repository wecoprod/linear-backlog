---
import KanbanBoard from '../components/KanbanBoard.astro';
import { getBacklog } from '../lib/linear';
import type { BacklogData } from '../lib/linear';
import { getT } from '../lib/i18n';

const label = import.meta.env.LINEAR_LABEL ?? 'show-backlog';
const t = getT(import.meta.env.BOARD_LOCALE ?? 'en');
const brand = import.meta.env.BRAND_COLOR ?? '#6366f1';
const title = import.meta.env.BOARD_TITLE ?? 'Backlog';
const description = import.meta.env.BOARD_DESCRIPTION ?? '';
const boardStates: string[] = import.meta.env.BOARD_STATES
  ? import.meta.env.BOARD_STATES.split(',').map((s: string) => s.trim()).filter(Boolean)
  : [];

function parseHex(hex: string): [number, number, number] {
  const h = hex.replace('#', '');
  const full = h.length === 3
    ? h.split('').map(c => c + c).join('')
    : h;
  return [
    parseInt(full.slice(0, 2), 16),
    parseInt(full.slice(2, 4), 16),
    parseInt(full.slice(4, 6), 16),
  ];
}

function mixHex(hex: string, base: string, amount: number): string {
  const [r1, g1, b1] = parseHex(hex);
  const [r2, g2, b2] = parseHex(base);
  const t = amount / 100;
  const r = Math.round(r1 * t + r2 * (1 - t));
  const g = Math.round(g1 * t + g2 * (1 - t));
  const b = Math.round(b1 * t + b2 * (1 - t));
  return `rgb(${r},${g},${b})`;
}

const brandBg      = mixHex(brand, '#f8f9fa', 6);
const brandBorder  = mixHex(brand, '#e0e0e0', 18);
const brandGlow    = mixHex(brand, '#ffffff', 20);
const brandCardBg  = mixHex(brand, '#f8f9fa', 3);

let columns: BacklogData = [];
let error: string | null = null;

try {
  const all = await getBacklog();
  if (boardStates.length > 0) {
    columns = boardStates
      .map(name => all.find(col => col.state.name === name))
      .filter((col): col is NonNullable<typeof col> => col != null);
  } else {
    columns = all;
  }
} catch (err) {
  error = err instanceof Error ? err.message : 'Failed to load issues';
  console.error('[linear-backlog] Failed to load backlog:', err);
}
---

<!DOCTYPE html>
<html lang={import.meta.env.BOARD_LOCALE ?? 'en'} style={`--brand:${brand};--brand-bg:${brandBg};--brand-border:${brandBorder};--brand-glow:${brandGlow};--brand-card-bg:${brandCardBg}`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--brand-bg);
      color: #1a1a1a;
    }
    header {
      padding: 1rem 2rem;
      border-bottom: 1px solid var(--brand-border);
      background: #fff;
      display: flex;
      align-items: center;
    }
    header h1 {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 600;
    }
    header p {
      margin: 0 0 0 1rem;
      font-size: 0.875rem;
      color: #888;
    }
    .error {
      margin: 2rem;
      padding: 1rem 1.5rem;
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 6px;
      color: #664d03;
    }
  </style>
</head>
<body>
  <header>
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </header>
  {error ? (
    <div class="error">
      <strong>Could not load issues.</strong> {error}
    </div>
  ) : (
    <KanbanBoard columns={columns} label={label} t={t} />
  )}
</body>
</html>
